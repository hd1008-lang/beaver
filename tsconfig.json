{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "types": ["node"],
        "baseUrl": ".",
        "paths": {
            "@src/*": ["./src/*"],
            "@utils/*": ["./src/utils/*"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules", "**/*.test.ts"]
}